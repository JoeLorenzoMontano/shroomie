# Shroomie Web Environment Variables

# API Keys (optional - many features work without these)
# MAPBOX_TOKEN=your_mapbox_token_here
# GFW_API_KEY=your_global_forest_watch_api_key_here
# OPENMETEO_API_KEY=your_open_meteo_api_key_here

# OpenStreetMap API User Agent Information
OSM_USER_AGENT=ShroomieWebApp/1.0
OSM_CONTACT_URL=https://github.com/shroomie
OSM_CONTACT_EMAIL=admin@localhost

# Flask Configuration
PORT=5000
FLASK_APP=app.py
FLASK_ENV=production
